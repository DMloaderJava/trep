# Supabase
# Эти переменные нужно установить в Vercel Dashboard (Settings → Environment Variables)
# как для Production, так и для Preview/Development окружений.
# Значения берутся из Supabase Dashboard → Settings → API

# URL вашего Supabase проекта (Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Публичный анонимный ключ (anon public key)
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here